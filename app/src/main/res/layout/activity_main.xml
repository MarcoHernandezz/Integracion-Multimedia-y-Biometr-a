<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- ESTADO 1: BLOQUEO / LOGIN -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutLock"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="@string/login_button_text"
            android:textAllCaps="false"
            android:letterSpacing="0.05"
            android:textSize="16sp"
            app:cornerRadius="28dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPinManual"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ingresar PIN manual"
            android:textColor="@color/secondary"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            tools:visibility="visible" />

        <!-- Teclado Numérico Custom In-App -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutCustomKeyboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnPinManual">

            <TextView
                android:id="@+id/tvPinDisplay"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:background="@drawable/pin_display_bg"
                android:gravity="center"
                android:letterSpacing="0.5"
                android:textColor="@color/onBackground"
                android:textSize="24sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="****" />

            <GridLayout
                android:id="@+id/keyboardGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPinDisplay">

                <!-- Botones del 1 al 9 -->
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="1"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="2"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="3"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="4"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="5"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="6"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="7"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="8"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />
                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="9"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />

                <!-- Botón de Borrar (Vacío para alineación si prefieres 0 al centro) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKeyDelete"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="←"
                    android:textColor="#FF8A80"
                    android:textSize="20sp" />

                <com.google.android.material.button.MaterialButton
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="0"
                    android:textSize="20sp"
                    android:onClick="onKeyClick" />

                <!-- Botón de Palomita (Continuar) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKeyDone"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="✓"
                    android:textColor="#81C784"
                    android:textSize="20sp" />
            </GridLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:gravity="center"
            android:textColor="#FF8A80"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutCustomKeyboard"
            tools:text="Intento fallido"
            tools:visibility="visible" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ESTADO 2: TERMINAL / CÁMARA -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCamera"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="visible">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCamera"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="32dp"
            app:cardElevation="8dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/outline"
            app:layout_constraintDimensionRatio="H,1:1.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnCapture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:contentDescription="Capturar Identidad"
            app:backgroundTint="@color/primary"
            app:fabCustomSize="72dp"
            app:maxImageSize="40dp"
            app:srcCompat="@android:drawable/ic_menu_camera"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardCamera" />

        <TextView
            android:id="@+id/tvCaptureHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Capturar Identidad"
            android:textColor="@color/onBackground"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@id/btnCapture"
            app:layout_constraintStart_toStartOf="@id/btnCapture"
            app:layout_constraintTop_toBottomOf="@id/btnCapture" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSwitchCamera"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Cambiar Cámara"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_menu_rotate"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvCaptureHint" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStopCamera"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Cerrar Sesión / Apagar Cámara"
            android:textColor="#FF8A80"
            app:strokeColor="#FF8A80"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSwitchCamera" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>